---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Message sent — AI Creator Stack"
  description="Thanks for reaching out to AI Creator Stack. We'll get back to you soon."
  canonicalPath="/thank-you"
>
  <div class="container prose" style="text-align:center;">
    <h1>Thanks for reaching out!</h1>
    <p>
      Your message has been sent. We read every message and typically reply within a few days.
    </p>
    <p><a href="/" class="btn btn-primary">Back to homepage</a></p>
  </div>
</BaseLayout>
